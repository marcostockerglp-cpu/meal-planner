VITE_API_BASE_URL=https://deine-api-domain.com

# Firebase – Google SSO
# 1. Gehe zu https://console.firebase.google.com
# 2. Neues Projekt erstellen
# 3. Web-App hinzufügen → Config-Objekt kopieren
# 4. Authentication → Sign-in method → Google aktivieren
# 5. Authentication → Settings → Authorized domains → Produktions-Domain hinzufügen
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
